# ============================================================
# .env 配置文件说明
# ============================================================
# 只需要配置 API Keys，其他配置（model、voice 等）可在前端"系统配置"页面设置
# 前端保存后会自动同步到 app_config.json 和 .env
# ============================================================

# ---- 必填：LLM API Key（文案生成、分类） ----
# 三选一，根据 app_config.json 中的 llm.provider 决定读哪个
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# KIMI_API_KEY=sk-your-kimi-key
# KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions

# ---- 必填：TTS API Key（语音合成） ----
# 根据 app_config.json 中的 tts.provider 决定读哪个
MIMO_API_KEY=your-mimo-key
# MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1

# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_GROUP_ID=your-minimax-group-id

# ---- 必填：Vision API Key（素材分类） ----
# 根据 app_config.json 中的 vision.provider 决定读哪个
XIAOMI_VISION_API_KEY=your-xiaomi-vision-key
# XIAOMI_VISION_API_URL=https://api.xiaomimimo.com/v1/chat/completions
# XIAOMI_VISION_MODEL=mimo-v2.5

# VISION_API_KEY=your-vision-key
# VISION_API_URL=https://api.example.com/v1/chat/completions
# VISION_MODEL=mimo-v2.5

# ---- 可选：Windows 专用路径 ----
# FFMPEG_PATH=tools\bin\ffmpeg.exe
# FFPROBE_PATH=tools\bin\ffprobe.exe
